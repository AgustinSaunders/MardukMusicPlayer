<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com" xmlns:fx="http://javafx.com"
            prefHeight="700.0" prefWidth="1000.0" styleClass="main-container">

    <!-- SIDE BARRA (Library and Playlists) -->
    <left>
        <VBox spacing="15" prefWidth="200" styleClass="sidebar">
            <padding><Insets top="20" right="10" bottom="20" left="10"/></padding>
            <Label text="MARDUK PLAYER" styleClass="logo-text"/>
            <Button text="Start" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Library" maxWidth="Infinity" styleClass="nav-button"/>
            <Separator styleClass="menu-separator"/>
            <Label text="PLAYLISTS" styleClass="section-header"/>
            <ListView fx:id="playlistList" VBox.vgrow="ALWAYS" styleClass="playlist-view"/>
        </VBox>
    </left>

    <!-- CENTRAL PANEL (Song List) -->
    <center>
        <VBox spacing="10">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="Your Music" styleClass="main-title"/>
            <TableView fx:id="songTable" VBox.vgrow="ALWAYS" styleClass="song-table">
                <columns>
                    <TableColumn text="Títle" prefWidth="300"/>
                    <TableColumn text="Artist" prefWidth="200"/>
                    <TableColumn text="Album" prefWidth="200"/>
                    <TableColumn text="Duration" prefWidth="80"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- BOTOM BAR (Playback Controls) -->
    <bottom>
        <HBox alignment="CENTER" prefHeight="100" spacing="30" styleClass="player-bar">
            <padding><Insets right="20" left="20"/></padding>

            <!-- Current Song Info -->
            <VBox alignment="CENTER_LEFT" prefWidth="200">
                <Label text="No Song" styleClass="current-song-title"/>
                <Label text="Select file" styleClass="current-song-artist"/>
            </VBox>

            <!-- Central Controls -->
            <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER" spacing="20">
                    <Button styleClass="control-button">
                        <graphic>
                            <FontIcon iconLiteral="fas-step-backward" iconSize="25" styleClass="play-icon-color"/>
                        </graphic>
                    </Button>
                    <Button styleClass="play-button">
                        <graphic>
                            <FontIcon iconLiteral="fas-play" iconSize="25" styleClass="play-icon-color"/>
                        </graphic>
                    </Button>
                    <Button styleClass="control-button">
                        <graphic>
                            <FontIcon iconLiteral="fas-step-forward" iconSize="25" styleClass="play-icon-color"/>
                        </graphic>
                    </Button>
                </HBox>
                <Slider fx:id="progressBar" maxWidth="600" styleClass="progress-slider"/>
            </VBox>

            <!-- Volume Control -->
            <HBox alignment="CENTER" spacing="10" prefWidth="200">
                <FontIcon iconLiteral="fas-volume-up" iconSize="25" styleClass="play-icon-color"/>
                <Slider fx:id="volumeSlider" value="50" prefWidth="100" styleClass="volume-slider"/>
            </HBox>
        </HBox>
    </bottom>
</BorderPane>